pipeline {
  agent { label 'joey-host' }
  options { disableConcurrentBuilds() }

  parameters {
    string(name: 'WAS_TAG', defaultValue: '', description: 'Optional cba_was_renew image tag to deploy to dev, for example dev-202605291041-69d9e5d')
    string(name: 'MANAGEMENT_TAG', defaultValue: '', description: 'Optional cba_management image tag to deploy to dev')
    booleanParam(name: 'WAS_ONLY', defaultValue: false, description: 'Deploy only cba-was-renewal and its workers')
  }

  stages {
    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Deploy dev apps with Helm') {
      steps {
        sh '''
          set -e
          cd "${WORKSPACE}"

          args=""
          if [ -n "${WAS_TAG:-}" ]; then
            args="${args} --was-tag ${WAS_TAG}"
          fi
          if [ -n "${MANAGEMENT_TAG:-}" ]; then
            args="${args} --management-tag ${MANAGEMENT_TAG}"
          fi
          if [ "${WAS_ONLY:-false}" = "true" ]; then
            args="${args} --was-only"
          fi

          ./scripts/deploy/deploy-dev.sh ${args}
        '''
      }
    }

    stage('Check dev status') {
      steps {
        sh '''
          set -e
          cd "${WORKSPACE}"
          helm list -n cba-connect-dev
          kubectl get deploy,svc,ingress -n cba-connect-dev
          kubectl get pods -n cba-connect-dev
        '''
      }
    }
  }
}
